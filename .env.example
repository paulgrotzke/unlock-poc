# Local Supabase CLI:
# - Run: supabase status -o env
# - Use API_URL as VITE_SUPABASE_URL
# - Use ANON_KEY (JWT) as VITE_SUPABASE_ANON_KEY
# - Use SERVICE_ROLE_KEY (JWT) as SUPABASE_SERVICE_ROLE_KEY (for seeding only)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_JWT
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_JWT
